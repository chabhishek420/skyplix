# ZAI Keitaro TDS - Environment Configuration

# Admin API Key (Required for /api/admin/* endpoints)
# Use a strong secret key in production.
# This key is used for Bearer token and X-API-Key authentication.
# For cookie-based login, a SHA256 hash of this key is stored in the session cookie.
ADMIN_API_KEY=tds-admin-secret-key-change-in-production

# Web Dev SDK (Backend Only)
# Z_AI_API_KEY=your-z-ai-api-key

# Database
# DATABASE_URL="file:./db/custom.db"

# Node Environment
NODE_ENV=development
