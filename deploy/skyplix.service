[Unit]
Description=SkyPlix TDS Service
After=network.target postgresql.service clickhouse-server.service valkey.service

[Service]
Type=simple
User=skyplix
Group=skyplix
WorkingDirectory=/app
EnvironmentFile=/etc/skyplix/skyplix.env
ExecStart=/app/skyplix
Restart=on-failure
RestartSec=5
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
